{
  "name": "Micro Bookstore - Node.js",
  "image": "mcr.microsoft.com/devcontainers/nodejs:18",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "forwardPorts": [5000, 3000, 3002, 3001],
  "portsAttributes": {
    "5000": {
      "label": "Frontend",
      "onAutoForward": "notify"
    },
    "3000": {
      "label": "Controller",
      "onAutoForward": "notify"
    },
    "3002": {
      "label": "Inventory gRPC",
      "onAutoForward": "notify"
    },
    "3001": {
      "label": "Shipping gRPC",
      "onAutoForward": "notify"
    }
  },
  "postCreateCommand": "npm install",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.vscode-typescript-next",
        "dbaeumer.vscode-eslint",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "prettier.prettier"
      }
    }
  }
}
